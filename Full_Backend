              <div className="flex items-center space-x-4">
                <div className={`${getCategoryIcon(currentPod.category).color} rounded-full p-3`}>
                  <CategoryIcon className="w-8 h-8" />
                </div>
                <div>
                  <h2 className="text-2xl font-bold">{currentPod.name}</h2>
